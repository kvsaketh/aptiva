# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Auth: Firebase (backend) ───────────────────────────────────
FIREBASE_PROJECT_ID=      # Firebase project id — backend verifies ID tokens against it
OWNER_EMAIL=              # comma-separated emails granted the "admin" role

# ── Auth: Firebase (frontend — baked into the bundle at build) ─
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=        # e.g. your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=     # optional (e.g. your-project.appspot.com)
VITE_FIREBASE_MESSAGING_SENDER_ID= # optional

# ─────────────────────────────────────────────────────────────────────────
# Aptiva — PRODUCTION env (Oracle Cloud VM). Copy to `.env` ON THE SERVER.
# VITE_* values are BAKED IN at `npm run build`, so this file must exist and
# be correct BEFORE you build. The server reads the rest at runtime.
# Never commit the real .env — only this example is committed.
# ─────────────────────────────────────────────────────────────────────────

# ── Database: OCI MySQL HeatWave (managed) ─────────────────────
# Use the DB System's private endpoint/IP. URL-encode special chars in the password.
DATABASE_URL=mysql://admin:CHANGE_ME_STRONG_PASS@DB_PRIVATE_IP:3306/aptiva
# TLS (certificate verification is always ON). For OCI MySQL, download the CA
# bundle and point DB_SSL_CA at it (its cert isn't in the public trust store).
# DB_SSL=true with no CA verifies against Node's built-in roots instead.
DB_SSL=true
DB_SSL_CA=/home/ubuntu/aptiva/oci-mysql-ca.pem

# ── Auth: Firebase (backend token verification) ────────────────
# From your Firebase project. Public marketing site works even if blank;
# only /login + /admin need it. See deploy/FIREBASE.md.
FIREBASE_PROJECT_ID=your-firebase-project-id
OWNER_EMAIL=you@example.com           # comma-separated emails granted "admin"

# ── Auth: Firebase (frontend — BAKED INTO THE BUNDLE AT BUILD) ─
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=

# ── Runtime ────────────────────────────────────────────────────
PORT=3000                             # app listens here; Nginx proxies 443 → 3000
NODE_ENV=production
